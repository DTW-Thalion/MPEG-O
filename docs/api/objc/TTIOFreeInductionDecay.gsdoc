    <chapter>
      <heading>
        Software documentation for the TTIOFreeInductionDecay
        class
      </heading>
      <class name="TTIOFreeInductionDecay" super="TTIOSignalArray">
        <declared>TTIOFreeInductionDecay.h</declared>
        <desc>
          NMR free-induction decay. Subclass of TTIOSignalArray
          that uses the Complex128 precision (interleaved
          real/imag doubles) plus FID-specific acquisition
          metadata: dwell time, scan count, receiver gain.
          Length is the number of complex points (i.e. half the
          number of doubles in the buffer). Cross-language
          equivalents: Python: ttio.fid.FreeInductionDecay
          Java: global.thalion.ttio.FreeInductionDecay
        </desc>
        <method type="double">
          <sel>dwellTimeSeconds</sel>
          <desc>
            Getter for property 'dwellTimeSeconds' with
            attributes (readonly, atomic, assign).
          </desc>
        </method>
        <method type="instancetype">
          <sel>initWithComplexBuffer:</sel>
          <arg type="NSData*">buffer</arg>
          <sel>complexLength:</sel>
          <arg type="NSUInteger">length</arg>
          <sel>dwellTimeSeconds:</sel>
          <arg type="double">dwell</arg>
          <sel>scanCount:</sel>
          <arg type="NSUInteger">scanCount</arg>
          <sel>receiverGain:</sel>
          <arg type="double">gain</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="double">
          <sel>receiverGain</sel>
          <desc>
            Getter for property 'receiverGain' with attributes
            (readonly, atomic, assign).
          </desc>
        </method>
        <method type="NSUInteger">
          <sel>scanCount</sel>
          <desc>
            Getter for property 'scanCount' with attributes
            (readonly, atomic, assign).
          </desc>
        </method>
      </class>
