          <arg type="NSString*">path</arg>
          <sel>runName:</sel>
          <arg type="NSString*">runName</arg>
          <desc>
            Attaches file-path + run-name context after load
            so protocol encryption methods can delegate to the
            in-place encryption manager. Internal API.
          </desc>
        </method>
        <method type="void">
          <sel>setSignalCompression:</sel>
          <arg type="TTIOCompression">signalCompression</arg>
          <desc>
            Setter for property 'signalCompression' with
            attributes (nonatomic, readwrite, assign). See
            also
            <ref type="method" id="-signalCompression" class="TTIOAcquisitionRun">[TTIOAcquisitionRun -signalCompression]</ref> Compression codec applied to signal-channel datasets when persisting this run. Defaults to <code>TTIOCompressionZlib</code>; writers may set <code>LZ4</code> or <code>NumpressDelta</code> explicitly before calling <code><ref type="method" id="-writeToGroup:">-writeToGroup:</ref></code>.
          </desc>
        </method>
