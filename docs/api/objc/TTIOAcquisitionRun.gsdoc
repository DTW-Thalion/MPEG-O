        <method type="void">
          <sel>releaseHDF5Handles</sel>
          <desc>
            Releases all cached HDF5 handles (group +
            per-channel datasets). After this call
            <code>
              <ref type="method" id="-spectrumAtIndex:error:">
                -spectrumAtIndex:error:
              </ref>
            </code>
            fails; the run keeps its index metadata so
            <code>count</code> / headers remain queryable.
          </desc>
        </method>
