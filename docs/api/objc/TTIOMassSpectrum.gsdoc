          <sel>msLevel:</sel>
          <arg type="NSUInteger">msLevel</arg>
          <sel>polarity:</sel>
          <arg type="TTIOPolarity">polarity</arg>
          <sel>scanWindow:</sel>
          <arg type="TTIOValueRange*">scanWindow</arg>
          <sel>activationMethod:</sel>
          <arg type="TTIOActivationMethod">activationMethod</arg>
          <sel>isolationWindow:</sel>
