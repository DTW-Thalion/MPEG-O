          <sel>precursorCharge:</sel>
          <arg type="NSUInteger">precursorCharge</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Designated initializer (M74). Returns
            <code>nil</code> and populates `error` if
            <var>mz</var> and <var>intensity</var> have different
            lengths.
          </desc>
        </method>
        <method type="instancetype">
          <sel>initWithMzArray:</sel>
          <arg type="TTIOSignalArray*">mz</arg>
