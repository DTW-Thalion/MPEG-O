          <sel>datasetNamed:</sel>
          <arg type="NSString*">name</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSArray&lt;MPGOQuantification*&gt;*" factory="yes">
          <sel>readQuantificationsFromGroup:</sel>
          <arg type="MPGOHDF5Group*">parent</arg>
          <sel>datasetNamed:</sel>
          <arg type="NSString*">name</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="BOOL" factory="yes">
          <sel>writeCompoundHeadersForIndex:</sel>
          <arg type="MPGOSpectrumIndex*">index</arg>
          <sel>intoGroup:</sel>
          <arg type="MPGOHDF5Group*">parent</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Writes a single compound `headers` dataset alongside
            the existing parallel 1-D datasets under
            `spectrum_index/`. Purely additive; read
            path still uses the parallel arrays. This dataset
            exists primarily for external tooling / h5dump
            readability.
          </desc>
        </method>
        <method type="BOOL" factory="yes">
          <sel>writeGeneric:</sel>
          <arg type="NSArray&lt;NSDictionary*&gt;*">rows</arg>
          <sel>intoGroup:</sel>
          <arg type="MPGOHDF5Group*">parent</arg>
          <sel>datasetNamed:</sel>
          <arg type="NSString*">name</arg>
          <sel>fields:</sel>
          <arg type="NSArray&lt;MPGOCompoundField*&gt;*">fields</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Write an array of <var>rows</var> (each NSDictionary
            keyed by field <var>name</var>) into a compound
            dataset with the given schema.
          </desc>
        </method>
