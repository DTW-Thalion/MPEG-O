    <chapter>
      <heading>
        Software documentation for the MPGOCompoundIO class
      </heading>
      <class name="MPGOCompoundIO" super="NSObject">
        <declared>MPGOCompoundIO.h</declared>
        <desc>
          Compound-type persistence helpers for MPEG-O
          v0.2+ on-disk format. These helpers write and read
          native HDF5 compound datasets that replace the v0.1
          JSON-encoded string attributes. v0.1 files
          (detected by the absence of @mpeg_o_features on the
          root) are read via the old JSON path; v0.2+ writers
          always emit compound datasets and tag the root with
          the appropriate feature flag. All functions use
          variable-length C strings inside the compound
          records so h5dump can visualize them directly and
          external tools that understand compound types can
          introspect without a bespoke reader. API status:
          Stable (internal helper). Cross-language equivalents:
          Python: mpeg_o._hdf5_io (private helper module) Java:
          com.dtwthalion.mpgo.hdf5.Hdf5CompoundIO
          Each language exposes these differently due to HDF5
          binding shapes; see docs/api-review-v0.6.md for the
          documented stylistic difference.
        </desc>
        <method type="NSDictionary*" factory="yes">
          <sel>readCompoundHeaderRow:</sel>
          <arg type="NSUInteger">row</arg>
          <sel>fromGroup:</sel>
          <arg type="MPGOHDF5Group*">parent</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Verify the compound headers dataset exists and
            returns <var>row</var> i as an NSDictionary
            {offset, length, retention_time, ms_level,
            polarity, precursor_mz, precursor_charge,
            base_peak_intensity}. Used only by
            tests; main query paths still use the parallel
            datasets.
          </desc>
        </method>
        <method type="NSArray&lt;NSDictionary*&gt;*" factory="yes">
          <sel>readGenericFromGroup:</sel>
          <arg type="MPGOHDF5Group*">parent</arg>
          <sel>datasetNamed:</sel>
          <arg type="NSString*">name</arg>
          <sel>fields:</sel>
          <arg type="NSArray&lt;MPGOCompoundField*&gt;*">fields</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Read an existing compound dataset, returning rows as
            NSDictionary keyed by field <var>name</var>.
          </desc>
        </method>
        <method type="NSArray&lt;MPGOIdentification*&gt;*" factory="yes">
          <sel>readIdentificationsFromGroup:</sel>
          <arg type="MPGOHDF5Group*">parent</arg>
          <sel>datasetNamed:</sel>
          <arg type="NSString*">name</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSArray&lt;MPGOProvenanceRecord*&gt;*" factory="yes">
