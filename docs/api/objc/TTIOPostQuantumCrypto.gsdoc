    <chapter>
      <heading>
        Software documentation for the TTIOPQCKemEncapResult
        class
      </heading>
      <class name="TTIOPQCKemEncapResult" super="NSObject">
        <declared>TTIOPostQuantumCrypto.h</declared>
        <desc>
          Result of a KEM encapsulation: ciphertext to store on
          disk + the shared secret (32 bytes for ML-KEM-1024, used
          downstream as an AES-256 KEK).
        </desc>
        <method type="NSData*">
          <sel>ciphertext</sel>
          <desc>
            Getter for property 'ciphertext' with attributes
            (nonatomic, readonly, copy).
          </desc>
        </method>
        <method type="instancetype">
          <sel>initWithCiphertext:</sel>
          <arg type="NSData*">ciphertext</arg>
          <sel>sharedSecret:</sel>
          <arg type="NSData*">sharedSecret</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSData*">
          <sel>sharedSecret</sel>
          <desc>
            Getter for property 'sharedSecret' with attributes
            (nonatomic, readonly, copy).
          </desc>
        </method>
      </class>
    </chapter>
