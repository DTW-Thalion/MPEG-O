    <chapter>
      <heading>
        Software documentation for the TTIOAnonymizer class
      </heading>
      <class name="TTIOAnonymizer" super="NSObject">
        <declared>TTIOAnonymizer.h</declared>
        <desc>
          <em>Description forthcoming.</em>
        </desc>
        <method type="TTIOAnonymizationResult*" factory="yes">
          <sel>anonymizeDataset:</sel>
          <arg type="TTIOSpectralDataset*">source</arg>
          <sel>outputPath:</sel>
          <arg type="NSString*">outputPath</arg>
          <sel>policy:</sel>
          <arg type="TTIOAnonymizationPolicy*">policy</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Anonymize ``source`` under ``policy`` and write
            to ``outputPath``. Returns the result summary or
            <code>nil</code> on failure.
          </desc>
        </method>
      </class>
