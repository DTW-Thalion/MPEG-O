    <chapter>
      <heading>
        Software documentation for the TTIOStorageDataset
        protocol
      </heading>
      <protocol name="TTIOStorageDataset">
        <declared>TTIOStorageProtocols.h</declared>
        <conform>NSObject</conform>
        <desc>
          <p>
            <em>Conforms To:</em> NSObject (NSObject)
          </p>
          <p>
            <em>Declared In:</em> Providers/TTIOStorageProtocols.h
          </p>
          <p>
            A typed array (or compound record array) stored under a
            <code>TTIOStorageGroup</code>. 1-D is the common
            case; N-D is supported for image cubes and 2-D NMR
            data.
          </p>
          <p>
            <strong>API status:</strong> Provisional.
          </p>
          <p>
            <strong>Cross-language equivalents:</strong>
            <br /> Python:
            <code>ttio.providers.base.StorageDataset</code>
            <br /> Java:
            <code>
              global.thalion.ttio.providers.StorageDataset
            </code>
          </p>
        </desc>
        <method type="NSArray&lt;NSString*&gt;*">
          <sel>attributeNames</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="id">
          <sel>attributeValueForName:</sel>
          <arg type="NSString*">name</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSArray&lt;NSNumber*&gt;*">
          <sel>chunks</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="void">
          <sel>close</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSArray&lt;TTIOCompoundField*&gt;*">
          <sel>compoundFields</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="BOOL">
          <sel>deleteAttributeNamed:</sel>
          <arg type="NSString*">name</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="BOOL">
          <sel>hasAttributeNamed:</sel>
          <arg type="NSString*">name</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSUInteger">
          <sel>length</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSString*">
          <sel>name</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="TTIOPrecision">
          <sel>precision</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="id">
          <sel>readAll:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Full read. Return type varies by backend: - Primitive
            datasets: <code>NSData</code> of
            <code>length * sizeof(element)</code>. - Compound
            datasets (all backends):
            <code>NSArray&lt;NSDictionary *&gt;</code> where
            each dict maps field name to boxed value. The ObjC
            reference implementation returns this shape for
            both HDF5 and SQLite providers, so callers do not need
            to branch on provider type. The universal helper
            <code>
              <ref type="method" id="-readRows:">
                -readRows:
              </ref>
            </code>
            returns the same value and is provided for
            cross-language parity with Python and Java.
          </desc>
        </method>
        <method type="NSData*">
          <sel>readCanonicalBytes:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Returns the dataset contents as a byte stream in
            the TTIO canonical layout. Semantics: - Primitive
            numeric: little-endian packed values. - Compound:
            rows in storage order; fields in declaration order. VL
            strings as u32_le(length) || utf-8_bytes. Numeric
            fields little-endian. Signatures and encryption
            consume this so a <strong>signed</strong> or
            encrypted dataset verifies identically regardless
            of which provider wrote it. Required on the protocol
            because signature/encryption callers can never
            silently skip the canonicalisation step. Returns
            <code>nil</code> on read failure; populated NSError
            on failure.
          </desc>
        </method>
        <method type="NSArray&lt;NSDictionary&lt;NSString*,id&gt;*&gt;*">
          <sel>readRows:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Backend-agnostic compound read. Returns
            <code>NSArray&lt;NSDictionary *&gt;</code> for
            compound datasets, <code>nil</code> +
            <code>NSError</code> for primitives. ObjC compound
            readers already return the
            <code>NSDictionary</code> shape universally, so most
            implementations are a trivial forwarder to
            <code>
              <ref type="method" id="-readAll:">
                -readAll:
              </ref>
            </code>
            . Required on the protocol so that custom provider
            implementations that omit it fail at
            compile time rather than silently at runtime via
            <code>doesNotRecognizeSelector:</code>.
          </desc>
        </method>
        <method type="id">
          <sel>readSliceAtOffset:</sel>
          <arg type="NSUInteger">offset</arg>
          <sel>count:</sel>
          <arg type="NSUInteger">count</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Hyperslab read.
          </desc>
        </method>
        <method type="BOOL">
          <sel>setAttributeValue:</sel>
          <arg type="id">value</arg>
          <sel>forName:</sel>
          <arg type="NSString*">name</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSArray&lt;NSNumber*&gt;*">
          <sel>shape</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="BOOL">
          <sel>writeAll:</sel>
          <arg type="id">data</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Write. For primitives, ``data`` is NSData of length
            * sizeof(element); for compound, an
            NSArray&lt;NSDictionary *&gt;.
          </desc>
        </method>
      </protocol>
    </chapter>
    <chapter>
      <heading>
        Software documentation for the TTIOStorageGroup
        protocol
      </heading>
      <protocol name="TTIOStorageGroup">
        <declared>TTIOStorageProtocols.h</declared>
        <conform>NSObject</conform>
        <desc>
          <p>
            <em>Conforms To:</em> NSObject (NSObject)
          </p>
          <p>
            <em>Declared In:</em> Providers/TTIOStorageProtocols.h
          </p>
          <p>
            A named directory of sub-groups and datasets. Groups form
            a hierarchical namespace; every provider exposes at least
            one root group via <code>TTIOStorageProvider</code>.
            Upper-layer objects (
            <code>TTIOSpectralDataset</code>,
            <code>TTIOAcquisitionRun</code>,...) navigate the
            tree exclusively through this protocol.
          </p>
          <p>
            <strong>API status:</strong> Provisional.
          </p>
          <p>
            <strong>Cross-language equivalents:</strong>
            <br /> Python:
            <code>ttio.providers.base.StorageGroup</code> <br />
            Java:
            <code>
              global.thalion.ttio.providers.StorageGroup
            </code>
          </p>
        </desc>
        <method type="NSArray&lt;NSString*&gt;*">
          <sel>attributeNames</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="id">
          <sel>attributeValueForName:</sel>
          <arg type="NSString*">name</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSArray&lt;NSString*&gt;*">
          <sel>childNames</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="void">
          <sel>close</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="id&lt;TTIOStorageDataset&gt;">
          <sel>createCompoundDatasetNamed:</sel>
          <arg type="NSString*">name</arg>
          <sel>fields:</sel>
          <arg type="NSArray&lt;TTIOCompoundField*&gt;*">fields</arg>
          <sel>count:</sel>
          <arg type="NSUInteger">count</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="id&lt;TTIOStorageDataset&gt;">
          <sel>createDatasetNDNamed:</sel>
