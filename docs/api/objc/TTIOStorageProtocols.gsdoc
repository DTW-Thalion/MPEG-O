          <arg type="TTIOPrecision">precision</arg>
          <sel>shape:</sel>
          <arg type="NSArray&lt;NSNumber*&gt;*">shape</arg>
          <sel>chunks:</sel>
          <arg type="NSArray&lt;NSNumber*&gt;*">chunks</arg>
          <sel>compression:</sel>
