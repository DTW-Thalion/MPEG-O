    <chapter>
      <heading>
        Software documentation for the TTIOStorageProvider
        protocol
      </heading>
      <protocol name="TTIOStorageProvider">
        <declared>TTIOStorageProtocols.h</declared>
        <conform>NSObject</conform>
        <desc>
          <p>
            <em>Conforms To:</em> NSObject (NSObject)
          </p>
          <p>
            <em>Declared In:</em> Providers/TTIOStorageProtocols.h
          </p>
          <p>
            Storage backend entry point. A provider opens a
            backing store (HDF5 file, in-memory tree, Zarr
            store, SQLite database, etc.) and exposes its root
            <code>TTIOStorageGroup</code>. Providers are
            selected by scheme-based routing via
            <code>
              <ref type="method" id="-supportsURL:">
                -supportsURL:
              </ref>
            </code>
            or named explicitly through
            <code>TTIOProviderRegistry</code>. Upper layers talk
            only to the protocols and stay backend-agnostic.
          </p>
          <p>
            <strong>API status:</strong> Provisional.
          </p>
          <p>
            <strong>Cross-language equivalents:</strong>
            <br /> Python:
            <code>ttio.providers.base.StorageProvider</code>
            <br /> Java:
            <code>
              global.thalion.ttio.providers.StorageProvider
            </code>
          </p>
        </desc>
        <method type="void">
          <sel>beginTransaction</sel>
          <desc>
            Start a write-batching transaction. No-op on HDF5 and
            Memory; issues ``BEGIN`` on the underlying
            connection for SQLite.
          </desc>
        </method>
        <method type="void">
          <sel>close</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="void">
          <sel>commitTransaction</sel>
          <desc>
            Commit and end a transaction started with
            ``-beginTransaction``. No-op on HDF5
            and Memory.
          </desc>
        </method>
        <method type="BOOL">
          <sel>isOpen</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="id">
          <sel>nativeHandle</sel>
          <desc>
            Escape hatch returning the underlying native handle
            (``TTIOHDF5File`` for the HDF5 provider,
            <code>nil</code> for memory). Byte-level callers
            (signatures, encryption) use this.
          </desc>
        </method>
        <method type="BOOL">
          <sel>openURL:</sel>
          <arg type="NSString*">url</arg>
          <sel>mode:</sel>
          <arg type="TTIOStorageOpenMode">mode</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSString*">
          <sel>providerName</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="void">
          <sel>rollbackTransaction</sel>
          <desc>
            Roll back and end a transaction started with
            ``-beginTransaction``. No-op on HDF5
            and Memory.
          </desc>
        </method>
        <method type="id&lt;TTIOStorageGroup&gt;">
          <sel>rootGroupWithError:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="BOOL">
          <sel>supportsChunking</sel>
          <desc>
            <code>YES</code> if the backend honors ``chunkSize``
            in
            ``-createDatasetNamed:precision:length:chunkSize:...``.
            Defaults to <code>NO</code> via the adapter
            pattern — only ``TTIOHDF5Provider`` returns
            <code>YES</code>. Memory and SQLite accept the
            argument for interface compatibility but silently
            ignore it.
          </desc>
        </method>
        <method type="BOOL">
          <sel>supportsCompression</sel>
          <desc>
            <code>YES</code> if the backend honors
            <code>compression</code> /
            <code>compressionLevel</code>. Only
            <code>TTIOHDF5Provider</code> returns
            <code>YES</code> (zlib + LZ4).
          </desc>
        </method>
        <method type="BOOL">
          <sel>supportsURL:</sel>
          <arg type="NSString*">url</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
      </protocol>
    </chapter>
