        </method>
        <method type="TTIOAlignedRead*">
          <sel>readAtIndex:</sel>
          <arg type="NSUInteger">index</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Materialise the read at `index`. Returns
            <code>nil</code> and sets *error on invalid
            <var>index</var> or I/O failure.
          </desc>
        </method>
        <method type="NSUInteger">
          <sel>readCount</sel>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSString*">
          <sel>readNameAtIndex:</sel>
          <arg type="NSUInteger">index</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Return the read name at `index`. Dispatches on the
            on-disk read_names dataset shape (M86 Phase E): -
            Compound `{value: VL_STRING}`: existing M82 read
            path. - Flat 1-D uint8 with `@compression == 8`:
            NAME_TOKENIZED decode-once-and-cache. The
            decoded list is materialised on first call and held
            for the lifetime of this run instance per Binding
            Decision §114.
          </desc>
        </method>
        <method type="NSArray&lt;TTIOAlignedRead*&gt;*">
          <sel>readsInRegion:</sel>
          <arg type="NSString*">chromosome</arg>
          <sel>start:</sel>
          <arg type="int64_t">start</arg>
          <sel>end:</sel>
          <arg type="int64_t">end</arg>
          <desc>
            Reads on `chromosome` whose mapping position is in [
            <var>start</var>, <var>end</var>).
          </desc>
        </method>
        <method type="NSString*">
          <sel>referenceUri</sel>
          <desc>
            Getter for property 'referenceUri' with attributes
