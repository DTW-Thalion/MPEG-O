          </desc>
        </method>
        <method type="uint8_t">
          <sel>wireCompressionForChannel:</sel>
          <arg type="NSString*">name</arg>
          <desc>
            M90.10: return the M86 codec <strong>id</strong>
            (TTIOCompression value) declared on the
            named signal channel via its `@compression`
            attribute, or 0 (NONE) if the attribute is
            absent. The transport writer probes this for
            sequences/qualities to decide whether
            each per-AU slice should be re-encoded with that codec
            on the wire.
          </desc>
        </method>
