<!DOCTYPE gsdoc PUBLIC "-//GNUstep//DTD gsdoc 1.0.4//EN" "http://www.gnustep.org/gsdoc-1_0_4.dtd">
<gsdoc base="TTIOHDF5Types" stylesheeturl="default-styles.css">
  <head>
    <title>TTIOHDF5Types documentation</title>
    <author name="Generated by "></author>
    <date>Generated at 2026-04-25</date>
