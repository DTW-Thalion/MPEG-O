          </desc>
        </method>
        <method type="BOOL" factory="yes">
          <sel>isLegacyV1File:</sel>
          <arg type="MPGOHDF5Group*">root</arg>
          <desc>
            A v0.1 file has neither @mpeg_o_format_version nor
            @mpeg_o_features; it only has
            @mpeg_o_version.
          </desc>
        </method>
