        <method type="void">
          <sel>setUseChecksum:</sel>
          <arg type="BOOL">useChecksum</arg>
          <desc>
            Setter for property 'useChecksum' with attributes
            (nonatomic, readwrite, assign). See also
            <ref type="method" id="-useChecksum" class="TTIOTransportWriter">[TTIOTransportWriter -useChecksum]</ref> Whether each packet's payload is followed by a CRC-32C checksum (sets TTIOTransportPacketFlagHasChecksum). Default <code>NO</code>.
          </desc>
        </method>
        <method type="void">
          <sel>setUseCompression:</sel>
          <arg type="BOOL">useCompression</arg>
          <desc>
            Setter for property 'useCompression' with attributes
            (nonatomic, readwrite, assign). See also
            <ref type="method" id="-useCompression" class="TTIOTransportWriter">[TTIOTransportWriter -useCompression]</ref> Compress each channel's float64 bytes with zlib on the wire, setting ``TTIOCompressionZlib`` on the ChannelData. The reader decompresses automatically regardless of this flag. Default <code>NO</code>.
          </desc>
        </method>
        <method type="BOOL">
          <sel>useChecksum</sel>
          <desc>
            Getter for property 'useChecksum' with attributes
            (nonatomic, readwrite, assign). See also
            <ref type="method" id="-setUseChecksum:" class="TTIOTransportWriter">[TTIOTransportWriter -setUseChecksum:]</ref> Whether each packet's payload is followed by a CRC-32C checksum (sets TTIOTransportPacketFlagHasChecksum). Default <code>NO</code>.
          </desc>
        </method>
        <method type="BOOL">
          <sel>useCompression</sel>
          <desc>
            Getter for property 'useCompression' with attributes
            (nonatomic, readwrite, assign). See also
            <ref type="method" id="-setUseCompression:" class="TTIOTransportWriter">[TTIOTransportWriter -setUseCompression:]</ref> Compress each channel's float64 bytes with zlib on the wire, setting ``TTIOCompressionZlib`` on the ChannelData. The reader decompresses automatically regardless of this flag. Default <code>NO</code>.
          </desc>
        </method>
