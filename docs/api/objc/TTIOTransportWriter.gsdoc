        <method type="BOOL">
          <sel>writeGenomicRun:</sel>
          <arg type="TTIOGenomicRun*">run</arg>
          <sel>datasetId:</sel>
          <arg type="uint16_t">datasetId</arg>
          <sel>name:</sel>
          <arg type="NSString*">name</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            M89.2: emit a single GenomicRun as a stream segment.
            Writes the dataset header
            (spectrum_class="TTIOGenomicRead",
            channel_names=["sequences",
            "qualities"], reference/platform metadata in
            the instrument_json slot), then one ACCESS_UNIT per
            read with the genomic suffix populated, then
            end-of-dataset. The caller is responsible
            for stream framing
            (writeStreamHeader…/writeEndOfStream…).
            For full-dataset emission use ``writeDataset:`` which
            calls this internally for each genomic <var>run</var>
            after the MS runs.
          </desc>
        </method>
