          <sel>runName:</sel>
          <arg type="NSString*">runName</arg>
          <sel>chemicalEntity:</sel>
          <arg type="NSString*">chemicalEntity</arg>
          <desc>
            Minimal constructor; numeric + container fields
            default to empty/zero.
          </desc>
        </method>
