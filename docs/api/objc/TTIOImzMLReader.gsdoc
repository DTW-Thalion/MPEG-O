    <chapter>
      <heading>
        Software documentation for the TTIOImzMLPixelSpectrum
        class
      </heading>
      <class name="TTIOImzMLPixelSpectrum" super="NSObject">
        <declared>TTIOImzMLReader.h</declared>
        <desc>
          <p>
            <em>Inherits From:</em> NSObject
          </p>
          <p>
            <em>Conforms To:</em> NSObject (NSObject)
          </p>
          <p>
            <em>Declared In:</em> Import/TTIOImzMLReader.h
          </p>
          <p>
            One pixel's worth of parsed imzML data: spatial
            coordinates plus the mass-spectrometry
            intensity / m/z arrays that came out of the
            <code>.ibd</code> binary at the offsets named in the
            <code>.imzML</code> XML.
          </p>
          <p>
            In continuous mode every pixel's <code>mzArray</code>
            aliases the same shared <code>NSData</code>
            (allocated once for the run) &#8212; the Python
            reference implementation makes the same
            guarantee.
          </p>
        </desc>
        <method type="instancetype">
          <sel>initWithX:</sel>
          <arg type="NSInteger">x</arg>
          <sel>y:</sel>
          <arg type="NSInteger">y</arg>
          <sel>z:</sel>
          <arg type="NSInteger">z</arg>
          <sel>mzArray:</sel>
          <arg type="NSData*">mzArray</arg>
          <sel>intensityArray:</sel>
          <arg type="NSData*">intensityArray</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Public initialiser for callers that construct pixel
            spectra from in-memory buffers (for example
            <code>TTIOImzMLWriter</code> or tests). The importer
            itself uses a private init; this one accepts
            equal-length float64 mz + intensity
            <code>NSData</code> buffers and derives
            <code>mzCount</code>. @param <var>x</var> X
            coordinate of the pixel. @param <var>y</var> Y
            coordinate of the pixel. @param <var>z</var> Z
            coordinate of the pixel. @param
            <var>mzArray</var> Float64 m/z buffer. @param
            <var>intensityArray</var> Float64 intensity buffer of
            equal length. @param <var>error</var> Out-parameter
            populated when array sizes are invalid or
            unequal. @return An initialised pixel spectrum, or
            <code>nil</code> on malformed input.
          </desc>
        </method>
        <method type="NSData*">
          <sel>intensityArray</sel>
          <desc>
            Getter for property 'intensityArray' with attributes
            (strong, nonatomic, readonly).
          </desc>
        </method>
        <method type="NSData*">
          <sel>mzArray</sel>
          <desc>
            Getter for property 'mzArray' with attributes
            (strong, nonatomic, readonly).
          </desc>
        </method>
        <method type="NSUInteger">
          <sel>mzCount</sel>
          <desc>
            Getter for property 'mzCount' with attributes
            (nonatomic, readonly, assign).
          </desc>
        </method>
        <method type="NSInteger">
          <sel>x</sel>
          <desc>
            Getter for property 'x' with attributes (nonatomic,
            readonly, assign).
          </desc>
        </method>
        <method type="NSInteger">
          <sel>y</sel>
          <desc>
            Getter for property 'y' with attributes (nonatomic,
            readonly, assign).
          </desc>
        </method>
        <method type="NSInteger">
          <sel>z</sel>
          <desc>
            Getter for property 'z' with attributes (nonatomic,
            readonly, assign).
          </desc>
        </method>
      </class>
    </chapter>
