      <class name="TTIOImzMLReader" super="NSObject">
        <declared>TTIOImzMLReader.h</declared>
        <desc>
          <em>Description forthcoming.</em>
        </desc>
        <method type="TTIOImzMLImport*" factory="yes">
          <sel>readFromImzMLPath:</sel>
          <arg type="NSString*">imzmlPath</arg>
          <sel>ibdPath:</sel>
          <arg type="NSString*">ibdPath</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Reads an imzML +.ibd pair. @param
            <var>imzmlPath</var> Path to the <code>.imzML</code>
            XML metadata file. @param <var>ibdPath</var> Path to
            the <code>.ibd</code> binary, or <code>nil</code> to
            use the sibling <code>&lt;stem&gt;.ibd</code>. @param
            <var>error</var> Out-parameter populated on failure.
            @return A populated <code>TTIOImzMLImport</code>,
            or <code>nil</code> on failure.
          </desc>
        </method>
      </class>
