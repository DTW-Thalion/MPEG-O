          </desc>
        </method>
        <method type="BOOL">
          <sel>readAdditionalStudyContent:</sel>
          <arg type="TTIOHDF5Group*">studyGroup</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Subclasses override to read their own datasets
            under /study/ after the base dataset has been loaded.
            Default is a no-op.
          </desc>
        </method>
        <method type="NSDictionary&lt;NSString*,id&lt;TTIORun&gt;&gt;*">
          <sel>runs</sel>
          <desc>
            Phase 2 canonical accessor: every run in the file (MS
            + NMR + genomic) keyed by run name. Values conform to
            TTIORun so callers can iterate uniformly across
            modalities without forking on ms_runs vs
            genomic_runs. NMR runs (legacy plain
            NSArray-of-spectra values) are
            intentionally omitted because they do not yet
            conform to TTIORun in the ObjC tree; that aligns
            with the Python reference impl's intent that values be
            Run-protocol-conforming. Mirrors
            Python ``SpectralDataset.runs``. Phase 1 added
            :meth:`allRunsUnified` as the same
            intent under a longer name; Phase 2 promotes the
            accessor to ``runs`` and keeps the alias for the
            brief transition window.
          </desc>
        </method>
        <method type="NSDictionary&lt;NSString*,id&lt;TTIORun&gt;&gt;*">
          <sel>runsForSample:</sel>
          <arg type="NSString*">sampleURI</arg>
          <desc>
            Return every run associated with ``sampleURI``. A
            run is considered associated when its :meth:`-[TTIORun
            provenanceChain]` carries ``sampleURI``
            in any record's ``inputRefs``. Walks all modalities (MS,
            genomic) uniformly via the TTIORun protocol —
            closes the M91 cross- modality query gap that
            previously had to fork on access pattern.
            Returns an empty dict when no run matches.
          </desc>
        </method>
        <method type="NSDictionary&lt;NSString*,id&lt;TTIORun&gt;&gt;*">
          <sel>runsOfModality:</sel>
          <arg type="Class">runClass</arg>
          <desc>
            Return every run whose value is an instance of
            ``runClass``. Pass [TTIOAcquisitionRun class]
            to get MS+NMR runs of the flat-buffer kind; pass
            [TTIOGenomicRun class] for genomic only.
            Thin filter over :meth:`runs`.
          </desc>
        </method>
        <method type="void">
          <sel>setAccessPolicy:</sel>
          <arg type="TTIOAccessPolicy*">policy</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
        <method type="NSString*">
          <sel>title</sel>
          <desc>
            Getter for property 'title' with attributes (atomic,
            readonly, copy).
          </desc>
        </method>
        <method type="TTIOTransitionList*">
          <sel>transitions</sel>
          <desc>
            Getter for property 'transitions' with attributes
            (atomic, readonly, strong).
          </desc>
        </method>
        <method type="BOOL">
          <sel>writeAdditionalStudyContent:</sel>
          <arg type="TTIOHDF5Group*">studyGroup</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            Subclasses (e.g. TTIOMSImage) override to add
            their own datasets under /study/ after the base
            dataset has been written. The default is a no-op.
            Return <code>NO</code> to abort the write.
          </desc>
        </method>
        <method type="BOOL">
          <sel>writeToFilePath:</sel>
          <arg type="NSString*">path</arg>
          <sel>error:</sel>
          <arg type="NSError**">error</arg>
          <desc>
            <em>Description forthcoming.</em>
          </desc>
        </method>
      </class>
