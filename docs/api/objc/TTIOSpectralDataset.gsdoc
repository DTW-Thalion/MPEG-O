          <sel>provenanceRecords</sel>
          <desc>
            Getter for property 'provenanceRecords' with
            attributes (atomic, readonly, copy).
          </desc>
        </method>
        <method type="NSArray&lt;TTIOProvenanceRecord*&gt;*">
          <sel>provenanceRecordsForInputRef:</sel>
          <arg type="NSString*">ref</arg>
          <desc>
            Provenance records whose inputRefs contain
            `ref`.
          </desc>
        </method>
        <method type="id&lt;TTIOStorageProvider&gt;">
          <sel>provider</sel>
          <desc>
            Getter for property 'provider' with attributes
