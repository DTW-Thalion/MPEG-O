    <chapter>
      <heading>
        Software documentation for the
        TTIOTransportChannelData class
      </heading>
      <class name="TTIOTransportChannelData" super="NSObject">
        <declared>TTIOAccessUnit.h</declared>
        <desc>
          One signal channel inside an TTIOAccessUnit.
        </desc>
        <method type="instancetype" factory="yes">
          <sel>decodeFromBytes:</sel>
          <arg type="const uint8_t*">bytes</arg>
          <sel>length:</sel>
          <arg type="NSUInteger">length</arg>
          <sel>offset:</sel>
          <arg type="NSUInteger*">offset</arg>
          <desc>
            Decode one channel starting at ``offset``; on
            return, ``*offset`` is advanced past the channel.
            Returns <code>nil</code> on truncation.
          </desc>
        </method>
        <method type="void">
          <sel>appendToBuffer:</sel>
          <arg type="NSMutableData*">buf</arg>
          <desc>
            Append this channel's wire bytes onto ``buf``.
          </desc>
        </method>
