# GNUstep build artefacts
obj/
shared_obj/
*.o
*.d
*.so
*.so.*

# autogsdoc output
objc/Documentation/html/
objc/Documentation/libTTIO/
objc/Documentation/*.gsdoc
objc/Documentation/*.igsdoc

# Claude Code local state
.claude/

# OS / editor cruft
.DS_Store
*.swp
*~
.venv/

__pycache__/
*.egg-info/
*.pyc
python/dist/
python/build/
python/tests/fixtures/_generated/
python/tests/stress/benchmark_results.json

# Maven build output
java/target/

# Transient build/ scratch dir for cross-language fixtures + logs
build/

# ObjC test summary artifact
objc/tests.sum
objc/Tests/tests.sum

# Sphinx build cache (Python doc generator intermediate output;
# committed HTML lives under docs/api/python/).
python/docs/_build/

# samtools-generated FASTA index files (M88 reference-aware CRAM
# path). The reference FASTAs themselves are committed; the .fai
# indexes are reproducible at runtime via samtools and were
# deliberately excluded per the M88 spec — pinning them across
# machines would create spurious diffs (the index encodes byte
# offsets that change with line-ending normalisation).
*.fa.fai

# V1 (verification workplan): coverage artefacts.
python/coverage.xml
python/htmlcov/
python/.coverage
objc/coverage/

# V5 (verification workplan) test-runtime artefacts.
# - jqwik writes .jqwik-database next to the test run for shrinking.
# - clang-coverage runs without LLVM_PROFILE_FILE drop default.profraw
#   in the working directory; can appear if a tool is run by hand
#   without the build.sh --coverage harness.
java/.jqwik-database
**/default.profraw

# Cython-generated artefacts (M93/M94 codec acceleration).
# `.pyx` sources are committed; the C transpilation output and
# compiled extension are regenerated by `python setup.py build_ext`.
python/src/ttio/codecs/_*/*.c
python/src/ttio/codecs/_*/*.so

# M92/M94 benchmark workspace (large reference + chr22 datasets,
# DVC-tracked elsewhere; not vendored into this repo).
data/genomic/
tools/benchmarks/_work/
tools/benchmarks/_cache/

# Phase B (libttio_rans) CMake build directories. The C library
# sources under native/{src,include,tests,bench} are committed;
# build outputs are regenerated via `cmake .. && make`.
native/_build/
native/_build_tsan/
tools/perf/htscodecs/

# Perf-harness scratch outputs: benchmark JSONs, .tio files, ad-hoc
# binaries built outside the canonical build_and_run_*.sh harnesses.
tools/perf/_out_*/
